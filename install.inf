[Version]
signature = "$Windows NT$"

[DefaultInstall]
CopyFiles = Scheme.Cur, Scheme.Txt
AddReg    = Scheme.Reg

[DestinationDirs]
Scheme.Cur = 10,"%CUR_DIR%"
Scheme.Txt = 10,"%CUR_DIR%"

[Scheme.Reg]
;; This list must be updated for every cursor added.
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,"%10%\%CUR_DIR%\%pointer%,%10%\%CUR_DIR%\%help%,%10%\%CUR_DIR%\%work%,%10%\%CUR_DIR%\%busy%,%10%\%CUR_DIR%\%cross%,%10%\%CUR_DIR%\%text%,%10%\%CUR_DIR%\%pen%,%10%\%CUR_DIR%\%no%,%10%\%CUR_DIR%\%vert%,%10%\%CUR_DIR%\%hori%"

[Scheme.Cur]
left-ptr.cur
help.cur
working.ani
busy.ani
crosshair.cur
text.cur
pen.cur
no.cur
vert-resize.cur
hori-resize.cur

[Scheme.Txt]

[Strings]
CUR_DIR     = "Violet-Cursors"
SCHEME_NAME = "Violet Cursors"

pointer     = "left-ptr.cur"
help        = "help.cur"
work        = "working.ani"
busy        = "busy.ani"
cross       = "crosshair.cur"
text        = "text.cur"
pen         = "pen.cur"
no          = "no.cur"
vert        = "vert-resize.cur"
hori        = "hori-resize.cur"
